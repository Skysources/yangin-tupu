* { -webkit-tap-highlight-color: transparent; box-sizing: border-box; }

:root {
  --ink: #1D1D1F;
  --gray: #6E6E73;
  --hairline: rgba(0,0,0,.08);
  --glass: rgba(255,255,255,.58);
  --glass-strong: rgba(255,255,255,.72);
  --green: #34C759;
  --green-deep: #248A3D;
  --red: #FF3B30;
  --red-deep: #D70015;
  --amber: #B25000;
  --blue: #0071E3;
  --r-lg: 22px;
  --r-md: 16px;
  --r-sm: 12px;
}

.app {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
  color: var(--ink);
  background: linear-gradient(160deg, #EEF1F6 0%, #E8ECF3 40%, #EDEAF2 100%);
  padding-bottom: 80px;
  position: relative;
  overflow-x: hidden;
}

.blob { position: fixed; border-radius: 50%; filter: blur(90px); opacity: .5; pointer-events: none; z-index: 0; }
.b1 { width: 480px; height: 480px; background: #FFD6CF; top: -140px; right: -120px; }
.b2 { width: 420px; height: 420px; background: #CFE3FF; top: 30%; left: -160px; }
.b3 { width: 380px; height: 380px; background: #DFF5E1; bottom: -120px; right: 15%; }

.hataBand {
  position: relative; z-index: 30; text-align: center; padding: 10px 16px;
  background: var(--red); color: #fff; font-weight: 600; font-size: 13.5px;
}

.topBar {
  position: sticky; top: 0; z-index: 20;
  background: rgba(250,250,252,.65);
  -webkit-backdrop-filter: saturate(180%) blur(24px);
  backdrop-filter: saturate(180%) blur(24px);
  border-bottom: 0.5px solid var(--hairline);
}
.topInner { max-width: 1080px; margin: 0 auto; padding: 14px 18px 12px; }
.titleRow { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
.eyebrow { font-size: 11px; font-weight: 600; letter-spacing: .8px; text-transform: uppercase; color: var(--gray); }
.title { margin: 1px 0 0; font-size: 26px; font-weight: 700; letter-spacing: -.4px; }

.monthPicker {
  display: flex; align-items: center; gap: 2px;
  background: rgba(120,120,128,.12); border-radius: 12px; padding: 3px;
}
.mBtn {
  width: 34px; height: 34px; border: none; border-radius: 9px; cursor: pointer;
  background: transparent; font-size: 20px; color: var(--blue); line-height: 1;
  display: flex; align-items: center; justify-content: center;
}
.mBtn:active { background: rgba(120,120,128,.16); }
.mLabel { min-width: 116px; text-align: center; font-weight: 600; font-size: 15px; }

.statRow { display: flex; align-items: center; gap: 14px; margin-top: 12px; }
.ring {
  width: 54px; height: 54px; border-radius: 50%; flex-shrink: 0;
  background: conic-gradient(var(--green) calc(var(--p) * 1%), rgba(120,120,128,.15) 0);
  display: flex; align-items: center; justify-content: center; position: relative;
}
.ring::before { content: ""; position: absolute; inset: 6px; border-radius: 50%; background: rgba(250,250,252,.9); }
.ring span { position: relative; font-size: 13px; font-weight: 700; }
.statText { flex: 1; min-width: 0; }
.statBig { font-size: 17px; font-weight: 700; letter-spacing: -.2px; }
.statDim { font-weight: 500; color: var(--gray); font-size: 14px; }
.statSub { font-size: 13px; color: var(--gray); margin-top: 2px; display: flex; align-items: center; flex-wrap: wrap; }
.dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 5px; flex-shrink: 0; }
.dot.ok { background: var(--green); }
.dot.sorun { background: var(--red); }
.dot.bekliyor { background: rgba(120,120,128,.4); }

.addBtn {
  display: flex; align-items: center; gap: 6px; flex-shrink: 0;
  background: var(--blue); color: #fff; border: none; border-radius: 12px;
  padding: 9px 15px 9px 12px; cursor: pointer; font-family: inherit;
  font-size: 13.5px; font-weight: 600; box-shadow: 0 4px 14px rgba(0,113,227,.3);
  transition: transform .12s, filter .12s;
}
.addBtn:hover { filter: brightness(1.05); }
.addBtn:active { transform: scale(.97); }
.addPlus { font-size: 17px; font-weight: 700; line-height: 1; }

.controls { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; align-items: center; }
.segment {
  display: flex; background: rgba(120,120,128,.12); border-radius: 11px; padding: 2.5px; gap: 2px;
  overflow-x: auto; max-width: 100%;
}
.seg {
  border: none; background: transparent; cursor: pointer;
  font-family: inherit; font-size: 13.5px; font-weight: 600; color: var(--ink);
  padding: 7px 14px; border-radius: 9px; white-space: nowrap; transition: all .15s;
}
.segOn { background: rgba(255,255,255,.95); box-shadow: 0 1px 4px rgba(0,0,0,.12); }
.segOn.seg-ok { color: var(--green-deep); }
.segOn.seg-sorun { color: var(--red-deep); }

.search {
  flex: 1; min-width: 150px; padding: 9px 14px; font-size: 14px; font-family: inherit;
  border: none; border-radius: 11px; background: rgba(120,120,128,.12); color: var(--ink);
  outline: none; transition: background .15s, box-shadow .15s;
}
.search::placeholder { color: var(--gray); }
.search:focus { background: rgba(255,255,255,.9); box-shadow: 0 0 0 3px rgba(0,113,227,.25); }

.grid {
  max-width: 1080px; margin: 18px auto 0; padding: 0 18px;
  display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px;
  position: relative; z-index: 1;
}
.empty { grid-column: 1/-1; text-align: center; color: var(--gray); padding: 48px 0; font-size: 15px; }

.card {
  display: flex; align-items: center; gap: 13px; text-align: left;
  padding: 13px 14px; cursor: pointer; font-family: inherit; color: inherit;
  background: var(--glass);
  -webkit-backdrop-filter: blur(18px); backdrop-filter: blur(18px);
  border: 0.5px solid rgba(255,255,255,.7);
  border-radius: var(--r-md);
  box-shadow: 0 2px 10px rgba(30,35,50,.06);
  transition: transform .15s ease, box-shadow .15s ease;
}
.card:hover { transform: translateY(-2px) scale(1.005); box-shadow: 0 8px 24px rgba(30,35,50,.12); }
.card:active { transform: scale(.985); }
.card:focus-visible { outline: 3px solid var(--blue); outline-offset: 2px; }
.card.sorun { background: rgba(255,235,233,.6); border-color: rgba(255,59,48,.25); }
.card.ok { border-color: rgba(52,199,89,.3); }

.badge {
  min-width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 19px; font-weight: 700; letter-spacing: -.5px;
  background: rgba(120,120,128,.14); color: var(--ink);
}
.badge.ok { background: var(--green); color: #fff; box-shadow: 0 3px 10px rgba(52,199,89,.35); }
.badge.sorun { background: var(--red); color: #fff; box-shadow: 0 3px 10px rgba(255,59,48,.35); }
.badge.big { min-width: 54px; height: 54px; font-size: 24px; border-radius: 15px; }

.cardBody { flex: 1; min-width: 0; }
.cardLoc { font-weight: 600; font-size: 14.5px; letter-spacing: -.1px; line-height: 1.28; }
.cardMeta { display: flex; align-items: center; gap: 7px; margin-top: 3px; flex-wrap: wrap; font-size: 12px; color: var(--gray); font-weight: 500; }

.pill { font-size: 10.5px; font-weight: 700; padding: 2.5px 8px; border-radius: 999px; letter-spacing: .2px; }
.pillRed { background: rgba(255,59,48,.14); color: var(--red-deep); }
.pillAmber { background: rgba(255,159,10,.18); color: var(--amber); }

.mark { font-size: 17px; font-weight: 700; width: 22px; text-align: center; flex-shrink: 0; color: rgba(120,120,128,.5); }
.mark.ok { color: var(--green-deep); }
.mark.sorun { color: var(--red-deep); }

.overlay {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(20,22,30,.35);
  -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  display: flex; align-items: center; justify-content: center; padding: 20px;
  animation: fadeIn .18s ease;
}
@keyframes fadeIn { from { opacity: 0; } }

.sheet {
  width: 100%; max-width: 540px; max-height: 88vh; overflow-y: auto;
  background: var(--glass-strong);
  -webkit-backdrop-filter: saturate(180%) blur(28px); backdrop-filter: saturate(180%) blur(28px);
  border: 0.5px solid rgba(255,255,255,.8);
  border-radius: 24px; padding: 20px 20px 24px;
  box-shadow: 0 30px 80px rgba(10,15,30,.35);
  animation: popIn .22s cubic-bezier(.32,1.25,.5,1);
}
@keyframes popIn { from { opacity: 0; transform: scale(.94); } }
.grabber { display: none; }

.sheetHead { display: flex; align-items: center; gap: 12px; }
.sheetLoc { font-weight: 700; font-size: 17px; letter-spacing: -.2px; line-height: 1.22; }
.sheetType { font-size: 12.5px; color: var(--gray); font-weight: 500; margin-top: 2px; }
.closeBtn, .iconBtn {
  width: 32px; height: 32px; border: none; border-radius: 50%; cursor: pointer; flex-shrink: 0;
  background: rgba(120,120,128,.16); color: var(--gray); font-size: 13px; font-weight: 700;
}
.iconBtn { font-size: 15px; color: var(--blue); background: rgba(0,113,227,.12); }
.closeBtn:hover { background: rgba(120,120,128,.24); color: var(--ink); }
.iconBtn:hover { background: rgba(0,113,227,.2); }

.infoRow { display: flex; gap: 10px; margin-top: 16px; }
.infoBox {
  flex: 1; display: flex; flex-direction: column; gap: 2px;
  background: rgba(255,255,255,.55); border: 0.5px solid rgba(255,255,255,.7);
  border-radius: var(--r-sm); padding: 9px 13px;
}
.infoLbl { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .6px; color: var(--gray); }
.infoVal { font-weight: 700; font-size: 14px; }

.warnBand {
  margin-top: 10px; padding: 9px 13px; border-radius: var(--r-sm);
  background: rgba(255,59,48,.12); color: var(--red-deep);
  font-size: 13px; font-weight: 600; border: 0.5px solid rgba(255,59,48,.2);
}

.secTitle { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--gray); margin: 22px 0 9px; }

.checkGroup { display: flex; flex-direction: column; gap: 8px; }
.checkRow {
  display: flex; align-items: center; gap: 12px; padding: 13px 15px;
  font-size: 14px; background: rgba(255,255,255,.6);
  border: 0.5px solid rgba(255,255,255,.8);
  border-radius: var(--r-sm);
  box-shadow: 0 1px 3px rgba(30,35,50,.05);
  transition: box-shadow .15s, background .15s;
}
.checkRow:hover { background: rgba(255,255,255,.75); box-shadow: 0 3px 10px rgba(30,35,50,.08); }
.checkLbl { flex: 1; font-weight: 600; letter-spacing: -.1px; }

.miniSeg { display: flex; background: rgba(120,120,128,.14); border-radius: 10px; padding: 3px; gap: 3px; flex-shrink: 0; }
.ms {
  border: none; background: transparent; cursor: pointer; font-family: inherit;
  font-size: 12.5px; font-weight: 700; color: var(--gray);
